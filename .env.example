# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Auth0 (required for merchant login — MLH Best Use of Auth0)
# Create a Regular Web Application at https://manage.auth0.com
# Allowed Callback URLs: http://localhost:3000/auth/callback (and your production URL)
# Allowed Logout URLs: http://localhost:3000 (and your production URL)
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_SECRET=
APP_BASE_URL=http://localhost:3000

# Supabase (GEO "Add this to my website" → northbound-backpacks storefront)
# Create project at https://supabase.com, run supabase-geo-website-integration.sql
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional overrides (defaults shown)
SUPABASE_LISTINGS_TABLE=merchant_listings
SUPABASE_DESCRIPTION_COLUMN=description
