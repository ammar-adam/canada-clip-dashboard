# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Auth0 (required for merchant login — MLH Best Use of Auth0)
# Create a Regular Web Application at https://manage.auth0.com
# Allowed Callback URLs: http://localhost:3000/auth/callback (and your production URL)
# Allowed Logout URLs: http://localhost:3000 (and your production URL)
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_SECRET=
APP_BASE_URL=http://localhost:3000

# Supabase (optional — for live App Clip events + GEO "Apply to my website")
# Create project at https://supabase.com, run supabase-schema.sql, enable Replication for clip_events
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
